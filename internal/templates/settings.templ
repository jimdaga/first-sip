package templates

import (
	"fmt"
	"github.com/jimdaga/first-sip/internal/settingsvm"
)

// HeroTopBar renders the hamburger row inside the page-hero banner (mobile only).
templ HeroTopBar() {
	<div class="hero-topbar">
		<button class="hero-hamburger" onclick="toggleMobileSidebar()" aria-label="Toggle menu">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
	</div>
}

// AppSidebar renders the vertical sidebar navigation rail.
// activePage should be "dashboard", "history", "settings", or "dashboard-<pluginName>".
// plugins is the list of enabled plugins to show as sub-links under Dashboard.
templ AppSidebar(activePage string, plugins []SidebarPlugin) {
	<aside class="app-sidebar" id="app-sidebar">
		<a href="/dashboard" class="sidebar-brand">
			<img src="/static/img/coffeeicon.png" alt="" class="sidebar-brand-logo"/>
			<span class="sidebar-brand-title">First Sip</span>
		</a>
		<nav class="sidebar-nav">
			<a href="/dashboard" class={ sidebarLinkClass(activePage, "dashboard") }>
				<svg class="sidebar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="3" width="7" height="7"></rect>
					<rect x="14" y="3" width="7" height="7"></rect>
					<rect x="3" y="14" width="7" height="7"></rect>
					<rect x="14" y="14" width="7" height="7"></rect>
				</svg>
				<span class="sidebar-label">Dashboard</span>
			</a>
			if isDashboardActive(activePage) && len(plugins) > 0 {
				<div class="sidebar-sub-links">
					for _, p := range plugins {
						<a href={ templ.SafeURL("/plugins/" + p.PluginName) }
						   class={ dashboardSubLinkClass(activePage, p.PluginName) }>
							<span class="sidebar-sub-icon">{ p.Icon }</span>
							<span class="sidebar-label">{ p.DisplayName }</span>
						</a>
					}
				</div>
			}
			<a href="/history" class={ sidebarLinkClass(activePage, "history") }>
				<svg class="sidebar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="10"></circle>
					<polyline points="12 6 12 12 16 14"></polyline>
				</svg>
				<span class="sidebar-label">History</span>
			</a>
			<a href="/settings" class={ sidebarLinkClass(activePage, "settings") }>
				<svg class="sidebar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="3"></circle>
					<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
				</svg>
				<span class="sidebar-label">Settings</span>
			</a>
			if isSettingsActive(activePage) {
				<div class="sidebar-sub-links">
					<a href="/settings/plugins" class={ settingsSubLinkClass(activePage, "plugins") }>
						<span class="sidebar-label">Plugin Settings</span>
					</a>
				</div>
			}
		</nav>
		<div class="sidebar-bottom">
			<a href="/logout" class="sidebar-link sidebar-logout">
				<svg class="sidebar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
					<polyline points="16 17 21 12 16 7"></polyline>
					<line x1="21" y1="12" x2="9" y2="12"></line>
				</svg>
				<span class="sidebar-label">Logout</span>
			</a>
			<button class="sidebar-toggle" onclick="toggleSidebar()">
				<svg class="sidebar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="11 17 6 12 11 7"></polyline>
					<polyline points="18 17 13 12 18 7"></polyline>
				</svg>
				<span class="sidebar-toggle-label">Collapse</span>
			</button>
		</div>
	</aside>
	<div class="sidebar-backdrop" id="sidebar-backdrop" onclick="toggleMobileSidebar()"></div>
}


// TierPluginCounter renders the plugin usage counter for the settings page.
// It is also rendered as an OOB fragment (hx-swap-oob="true") to keep the counter in sync after toggles.
templ TierPluginCounter(tierInfo settingsvm.TierInfo) {
	if tierInfo.MaxEnabledPlugins < 0 {
		<div id="tier-plugin-counter" class="settings-tier-counter">
			<span class="settings-tier-count">Unlimited plugins</span>
		</div>
	} else {
		<div id="tier-plugin-counter" class="settings-tier-counter" hx-swap-oob="true">
			if tierInfo.AtPluginLimit {
				<span class="settings-tier-count-at-limit">{ fmt.Sprintf("%d/%d plugins enabled", tierInfo.EnabledCount, tierInfo.MaxEnabledPlugins) }</span>
				<a href={ templ.SafeURL(tierInfo.UpgradeURL) } class="settings-upgrade-link">Pro users get unlimited — learn more</a>
			} else {
				<span class="settings-tier-count">{ fmt.Sprintf("%d/%d plugins enabled", tierInfo.EnabledCount, tierInfo.MaxEnabledPlugins) }</span>
			}
		</div>
	}
}

// SettingsHubPage renders the top-level settings hub with tile grid linking to sub-pages.
templ SettingsHubPage(plugins []SidebarPlugin) {
	@Layout("Settings - First Sip") {
		<div class="app-layout">
			@AppSidebar("settings", plugins)
			<main class="app-content">
				<div class="page-hero">
					@HeroTopBar()
					<h1>Settings</h1>
					<p>Manage your account, plugins, and preferences</p>
				</div>
				<div class="settings-hub-grid">
					<a href="/settings/plugins" class="glass-card settings-hub-tile">
						<span class="settings-hub-tile-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
							</svg>
						</span>
						<span class="settings-hub-tile-title">Plugin Settings</span>
						<span class="settings-hub-tile-desc">Enable, configure, and schedule your plugins</span>
					</a>
					<div class="glass-card settings-hub-tile settings-hub-tile-disabled">
						<span class="settings-hub-tile-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
								<circle cx="12" cy="7" r="4"></circle>
							</svg>
						</span>
						<span class="settings-hub-tile-title">User Preferences</span>
						<span class="settings-hub-tile-desc">Coming soon</span>
					</div>
				</div>
				@AppFooter()
			</main>
		</div>
	}
}

// PluginSettingsPage renders the full plugin settings page with accordion list.
templ PluginSettingsPage(page settingsvm.SettingsPageViewModel, plugins []SidebarPlugin) {
	@Layout("Plugin Settings - First Sip") {
		<div class="app-layout">
			@AppSidebar("settings-plugins", plugins)
			<main class="app-content">
			<div class="page-hero">
				@HeroTopBar()
				<h1>Plugin Settings</h1>
				<p>Manage your plugins, schedules, and configuration</p>
			</div>
			<!-- Plugin usage counter -->
			@TierPluginCounter(page.TierInfo)
			<div id="settings-plugin-list">
				if len(page.Plugins) == 0 {
					<div class="empty-state">No plugins available. Check your plugin directory configuration.</div>
				} else {
					for _, plugin := range page.Plugins {
						@PluginAccordionRow(plugin)
					}
				}
			</div>
		@AppFooter()
		</main>
		</div>
		<script>
			// Accordion expand/collapse — clicking the row header toggles .settings-expanded
			document.addEventListener('click', function(e) {
				var header = e.target.closest('.settings-plugin-header');
				if (!header) return;
				// Don't toggle if clicking the enable/disable toggle switch
				if (e.target.closest('.settings-toggle')) return;
				var row = header.closest('.settings-plugin-row-wrapper');
				if (!row) return;
				row.classList.toggle('settings-expanded');
			});

			// Consolidated htmx:beforeSwap — record which rows are expanded before re-render.
			var _expandedRows = {};
			htmx.on('htmx:beforeSwap', function(evt) {
				var target = evt.detail.target;
				if (target && target.classList.contains('settings-plugin-row-wrapper') && target.classList.contains('settings-expanded')) {
					_expandedRows[target.id] = true;
				}
			});

			// Consolidated htmx:afterSwap — restore expanded state, handle save feedback, auto-expand.
			htmx.on('htmx:afterSwap', function(evt) {
				var target = evt.detail.target;
				if (!target) return;

				// (a) Restore expanded state after save / validation re-render.
				if (target.classList && target.classList.contains('settings-plugin-row-wrapper') && _expandedRows[target.id]) {
					target.classList.add('settings-expanded');
					delete _expandedRows[target.id];
				}

				// (b) If save returned data-saved="true", expand and revert button text after 2s.
				var savedBtn = target.querySelector ? target.querySelector('[data-saved="true"]') : null;
				if (savedBtn) {
					// Ensure row is expanded so user sees "Saved ✓"
					var row = savedBtn.closest('.settings-plugin-row-wrapper');
					if (row) row.classList.add('settings-expanded');
					setTimeout(function() {
						if (savedBtn && savedBtn.parentNode) {
							savedBtn.textContent = 'Save';
							savedBtn.removeAttribute('data-saved');
						}
					}, 2000);
				}

				// (c) Revert "Run Now" button after triggered feedback.
				var runNowBtn = target.id && target.id.startsWith('run-now-') ? target : null;
				if (runNowBtn) {
					setTimeout(function() {
						if (runNowBtn && runNowBtn.parentNode) {
							runNowBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg> Run Now';
						}
					}, 3000);
				}

				// (d) Auto-expand when enable toggle fires HX-Trigger: settings-auto-expand.
				var xhr = evt.detail.xhr;
				if (xhr) {
					var trigger = xhr.getResponseHeader('HX-Trigger');
					if (trigger && trigger.indexOf('settings-auto-expand') !== -1) {
						if (target && target.classList) target.classList.add('settings-expanded');
					}
				}

				// (d) Re-initialise tag inputs that appeared after swap.
				initTagInputs(target);
			});

			// ── Settings Tooltip ──────────────────────────────────────────────────
			// CSS-based tooltips via title attribute work in some browsers but are
			// inconsistent. We render a JS tooltip for .settings-tooltip-trigger elements.
			(function() {
				var tip = document.createElement('div');
				tip.className = 'settings-tooltip';
				document.body.appendChild(tip);
				document.addEventListener('mouseover', function(e) {
					var trigger = e.target.closest('.settings-tooltip-trigger[title]');
					if (!trigger) return;
					var text = trigger.getAttribute('title');
					if (!text) return;
					tip.textContent = text;
					var rect = trigger.getBoundingClientRect();
					tip.style.left = (rect.left + rect.width / 2) + 'px';
					tip.style.top = (rect.top - 8 + window.scrollY) + 'px';
					tip.style.transform = 'translate(-50%, -100%)';
					tip.classList.add('visible');
				});
				document.addEventListener('mouseout', function(e) {
					if (e.target.closest('.settings-tooltip-trigger')) {
						tip.classList.remove('visible');
					}
				});
			})();

			// ── Tag Input ─────────────────────────────────────────────────────────
			// Initialises .settings-tag-input-wrapper elements within a container.
			function initTagInputs(container) {
				var wrappers = (container && container.querySelectorAll) ? container.querySelectorAll('.settings-tag-input-wrapper') : [];
				for (var i = 0; i < wrappers.length; i++) {
					(function(wrapper) {
						if (wrapper._tagInitialised) return;
						wrapper._tagInitialised = true;

						var input = wrapper.querySelector('.settings-tag-text-input');
						var hidden = wrapper.querySelector('.settings-tag-hidden');
						var tagList = wrapper.querySelector('.settings-tag-list');

						if (!input || !hidden || !tagList) return;

						// Parse initial tags from hidden input value (JSON array or comma-separated).
						function parseTags(val) {
							if (!val) return [];
							val = val.trim();
							if (val.startsWith('[')) {
								try {
									var arr = JSON.parse(val);
									return arr.filter(function(t) { return t && t.trim(); });
								} catch(e) {}
							}
							return val.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
						}

						var tags = parseTags(hidden.value);

						function renderTags() {
							tagList.innerHTML = '';
							tags.forEach(function(tag, idx) {
								var badge = document.createElement('span');
								badge.className = 'settings-tag-badge';
								badge.textContent = tag;
								var btn = document.createElement('button');
								btn.type = 'button';
								btn.className = 'settings-tag-remove';
								btn.setAttribute('aria-label', 'Remove ' + tag);
								btn.textContent = '×';
								btn.addEventListener('click', function() {
									tags.splice(idx, 1);
									updateHidden();
									renderTags();
								});
								badge.appendChild(btn);
								tagList.appendChild(badge);
							});
							updateHidden();
						}

						function updateHidden() {
							hidden.value = JSON.stringify(tags);
						}

						function addTag(val) {
							val = val.trim();
							if (val && tags.indexOf(val) === -1) {
								tags.push(val);
								renderTags();
							}
							input.value = '';
						}

						input.addEventListener('keydown', function(e) {
							if (e.key === 'Enter' || e.key === ',') {
								e.preventDefault();
								addTag(input.value);
							} else if (e.key === 'Backspace' && input.value === '' && tags.length > 0) {
								tags.pop();
								renderTags();
							}
						});

						input.addEventListener('blur', function() {
							if (input.value.trim()) {
								addTag(input.value);
							}
						});

						renderTags();
					})(wrappers[i]);
				}
			}

			// Initialise tag inputs on page load and after any HTMX swap.
			initTagInputs(document);
			htmx.onLoad(function(content) {
				initTagInputs(content);
			});
		</script>
	}
}

// PluginAccordionRow renders a single plugin row with a collapsible settings panel.
// The outer wrapper carries the id used by HTMX outerHTML swap targets.
templ PluginAccordionRow(plugin settingsvm.PluginSettingsViewModel) {
	<div
		id={ fmt.Sprintf("plugin-row-%d", plugin.PluginID) }
		if plugin.ForceExpanded {
			class="settings-plugin-row-wrapper settings-expanded"
		} else {
			class="settings-plugin-row-wrapper"
		}
	>
		<!-- Collapsed header — always visible -->
		<div class="settings-plugin-header settings-plugin-row">
			<!-- Status dot: gray when disabled, otherwise reflect health color -->
			if !plugin.Enabled {
				<span class="settings-status-dot settings-status-gray"></span>
			} else if plugin.Status != nil {
				<span class={ fmt.Sprintf("settings-status-dot settings-status-%s", plugin.Status.HealthColor) }></span>
			} else {
				<span class="settings-status-dot settings-status-gray"></span>
			}
			<!-- Plugin icon + display name -->
			if plugin.Icon != "" {
				<span class="settings-plugin-icon">{ plugin.Icon }</span>
			}
			<span class="settings-plugin-name">{ plugin.DisplayName }</span>
			<!-- Enable / disable toggle — disabled when at tier limit and not currently enabled -->
			if plugin.IsDisabledByTier {
				<label
					class="settings-toggle settings-toggle-disabled settings-tooltip-trigger"
					onclick="event.stopPropagation()"
					title="You've reached your 3-plugin limit. Disable another plugin or upgrade to Pro."
				>
					<input
						type="checkbox"
						class="settings-toggle-input"
						disabled
					/>
					<span class="settings-toggle-slider"></span>
				</label>
			} else {
				<label class="settings-toggle" onclick="event.stopPropagation()">
					<input
						type="checkbox"
						class="settings-toggle-input"
						hx-post={ fmt.Sprintf("/api/settings/%d/toggle", plugin.PluginID) }
						hx-target={ fmt.Sprintf("#plugin-row-%d", plugin.PluginID) }
						hx-swap="outerHTML"
						if plugin.Enabled {
							checked
						}
					/>
					<span class="settings-toggle-slider"></span>
				</label>
			}
			<!-- Chevron -->
			<svg class="settings-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="6 9 12 15 18 9"></polyline>
			</svg>
		</div>
		<!-- Expanded content — shown when .settings-expanded is on the wrapper -->
		<div class="settings-plugin-expanded">
			<div class="settings-expanded-grid">
				@PluginSettingsForm(plugin)
				@PluginStatusSection(plugin)
			</div>
		</div>
	</div>
}

// PluginSettingsForm renders the schedule and schema-driven settings form for a plugin.
templ PluginSettingsForm(plugin settingsvm.PluginSettingsViewModel) {
	<div class="settings-form-section">
		<h3 class="settings-section-heading">Configuration</h3>
		<form id={ fmt.Sprintf("settings-form-%d", plugin.PluginID) }>
			<!-- Schedule section -->
			<div class="settings-subsection">
				<h4 class="settings-subsection-heading">Schedule</h4>
				<div class="settings-field-group">
					<label class="settings-field-label" for={ fmt.Sprintf("cron-%d", plugin.PluginID) }>
						Cron Expression
						<span class="settings-tooltip-trigger" title="Standard 5-field cron expression (minute hour day month weekday). Example: 0 7 * * * for daily at 7am.">?</span>
					</label>
					<input
						type="text"
						id={ fmt.Sprintf("cron-%d", plugin.PluginID) }
						name="cron_expression"
						value={ plugin.CronExpression }
						class="settings-input"
						placeholder="0 7 * * *"
					/>
					<div id={ fmt.Sprintf("error-cron_expression-%d", plugin.PluginID) } class="settings-field-error">
					if plugin.CronError != "" {
						{ plugin.CronError }
					}
				</div>
				<!-- Pro hint for free users: schedules faster than daily require Pro -->
				if plugin.IsFreeUser {
					<span class="settings-field-hint settings-pro-hint">
						Schedules faster than once daily require <a href="/pro" class="settings-pro-link">Pro</a>
					</span>
				}
				<!-- Frequency error from tier enforcement -->
				if plugin.FrequencyError != "" {
					<span class="settings-field-error">{ plugin.FrequencyError }</span>
				}
				</div>
				<div class="settings-field-group">
					<label class="settings-field-label" for={ fmt.Sprintf("tz-%d", plugin.PluginID) }>
						Timezone
					</label>
					@renderTimezoneSelect(fmt.Sprintf("tz-%d", plugin.PluginID), plugin.Timezone)
				</div>
			</div>
			<!-- Plugin-specific fields (from JSON Schema) -->
			if plugin.HasSchema && len(plugin.Fields) > 0 {
				<div class="settings-subsection">
					<h4 class="settings-subsection-heading">Plugin Settings</h4>
					for _, field := range plugin.Fields {
						@renderField(plugin.PluginID, field)
					}
				</div>
			}
			<!-- Save button -->
			<button
				type="button"
				class="glass-btn glass-btn-primary"
				hx-post={ fmt.Sprintf("/api/settings/%d/save", plugin.PluginID) }
				hx-include={ fmt.Sprintf("#settings-form-%d", plugin.PluginID) }
				hx-target={ fmt.Sprintf("#plugin-row-%d", plugin.PluginID) }
				hx-swap="outerHTML"
				if plugin.SaveSuccess {
					data-saved="true"
				}
			>
				if plugin.SaveSuccess {
					Saved ✓
				} else {
					Save
				}
			</button>
		</form>
	</div>
}

// renderTimezoneSelect renders a <select> for the timezone field pre-populated
// with a curated list of common IANA timezones.
templ renderTimezoneSelect(id, currentValue string) {
	<select id={ id } name="timezone" class="settings-select">
		<option value="" if currentValue == "" { selected }>— Select timezone —</option>
		<!-- UTC -->
		<option value="UTC" if currentValue == "UTC" { selected }>UTC</option>
		<!-- Americas -->
		<option value="America/New_York" if currentValue == "America/New_York" { selected }>Eastern Time (New York)</option>
		<option value="America/Chicago" if currentValue == "America/Chicago" { selected }>Central Time (Chicago)</option>
		<option value="America/Denver" if currentValue == "America/Denver" { selected }>Mountain Time (Denver)</option>
		<option value="America/Phoenix" if currentValue == "America/Phoenix" { selected }>Mountain Time no DST (Phoenix)</option>
		<option value="America/Los_Angeles" if currentValue == "America/Los_Angeles" { selected }>Pacific Time (Los Angeles)</option>
		<option value="America/Anchorage" if currentValue == "America/Anchorage" { selected }>Alaska Time (Anchorage)</option>
		<option value="Pacific/Honolulu" if currentValue == "Pacific/Honolulu" { selected }>Hawaii Time (Honolulu)</option>
		<option value="America/Toronto" if currentValue == "America/Toronto" { selected }>Eastern Time (Toronto)</option>
		<option value="America/Vancouver" if currentValue == "America/Vancouver" { selected }>Pacific Time (Vancouver)</option>
		<option value="America/Sao_Paulo" if currentValue == "America/Sao_Paulo" { selected }>Brazil Time (São Paulo)</option>
		<option value="America/Argentina/Buenos_Aires" if currentValue == "America/Argentina/Buenos_Aires" { selected }>Argentina (Buenos Aires)</option>
		<option value="America/Mexico_City" if currentValue == "America/Mexico_City" { selected }>Central Time (Mexico City)</option>
		<!-- Europe -->
		<option value="Europe/London" if currentValue == "Europe/London" { selected }>London (GMT/BST)</option>
		<option value="Europe/Paris" if currentValue == "Europe/Paris" { selected }>Central European (Paris)</option>
		<option value="Europe/Berlin" if currentValue == "Europe/Berlin" { selected }>Central European (Berlin)</option>
		<option value="Europe/Rome" if currentValue == "Europe/Rome" { selected }>Central European (Rome)</option>
		<option value="Europe/Madrid" if currentValue == "Europe/Madrid" { selected }>Central European (Madrid)</option>
		<option value="Europe/Amsterdam" if currentValue == "Europe/Amsterdam" { selected }>Central European (Amsterdam)</option>
		<option value="Europe/Stockholm" if currentValue == "Europe/Stockholm" { selected }>Central European (Stockholm)</option>
		<option value="Europe/Helsinki" if currentValue == "Europe/Helsinki" { selected }>Eastern European (Helsinki)</option>
		<option value="Europe/Athens" if currentValue == "Europe/Athens" { selected }>Eastern European (Athens)</option>
		<option value="Europe/Moscow" if currentValue == "Europe/Moscow" { selected }>Moscow Time</option>
		<option value="Europe/Istanbul" if currentValue == "Europe/Istanbul" { selected }>Turkey Time (Istanbul)</option>
		<!-- Asia / Pacific -->
		<option value="Asia/Dubai" if currentValue == "Asia/Dubai" { selected }>Gulf Standard Time (Dubai)</option>
		<option value="Asia/Karachi" if currentValue == "Asia/Karachi" { selected }>Pakistan Time (Karachi)</option>
		<option value="Asia/Kolkata" if currentValue == "Asia/Kolkata" { selected }>India Time (Kolkata)</option>
		<option value="Asia/Dhaka" if currentValue == "Asia/Dhaka" { selected }>Bangladesh Time (Dhaka)</option>
		<option value="Asia/Bangkok" if currentValue == "Asia/Bangkok" { selected }>Indochina Time (Bangkok)</option>
		<option value="Asia/Singapore" if currentValue == "Asia/Singapore" { selected }>Singapore Time</option>
		<option value="Asia/Shanghai" if currentValue == "Asia/Shanghai" { selected }>China Time (Shanghai)</option>
		<option value="Asia/Tokyo" if currentValue == "Asia/Tokyo" { selected }>Japan Time (Tokyo)</option>
		<option value="Asia/Seoul" if currentValue == "Asia/Seoul" { selected }>Korea Time (Seoul)</option>
		<option value="Asia/Hong_Kong" if currentValue == "Asia/Hong_Kong" { selected }>Hong Kong Time</option>
		<option value="Australia/Sydney" if currentValue == "Australia/Sydney" { selected }>Eastern Australia (Sydney)</option>
		<option value="Australia/Melbourne" if currentValue == "Australia/Melbourne" { selected }>Eastern Australia (Melbourne)</option>
		<option value="Australia/Perth" if currentValue == "Australia/Perth" { selected }>Western Australia (Perth)</option>
		<option value="Pacific/Auckland" if currentValue == "Pacific/Auckland" { selected }>New Zealand (Auckland)</option>
		<!-- Africa -->
		<option value="Africa/Cairo" if currentValue == "Africa/Cairo" { selected }>Egypt Time (Cairo)</option>
		<option value="Africa/Johannesburg" if currentValue == "Africa/Johannesburg" { selected }>South Africa Time (Johannesburg)</option>
		<option value="Africa/Lagos" if currentValue == "Africa/Lagos" { selected }>West Africa Time (Lagos)</option>
		<option value="Africa/Nairobi" if currentValue == "Africa/Nairobi" { selected }>East Africa Time (Nairobi)</option>
	</select>
}

// renderField dispatches to the correct input component based on FieldType.
templ renderField(pluginID uint, field settingsvm.FieldViewModel) {
	<div class="settings-field-group">
		<label class="settings-field-label">
			{ field.Label }
			if field.Required {
				<span class="settings-required-marker" title="Required">*</span>
			}
			if field.Description != "" {
				<span class="settings-tooltip-trigger" title={ field.Description }>?</span>
			}
		</label>
		switch field.FieldType {
			case settingsvm.FieldTypeText:
				@renderTextField(pluginID, field)
			case settingsvm.FieldTypeTimeSelect:
				@renderTimeSelectField(pluginID, field)
			case settingsvm.FieldTypeInteger:
				@renderIntegerField(pluginID, field)
			case settingsvm.FieldTypeBoolean:
				@renderBooleanField(pluginID, field)
			case settingsvm.FieldTypeEnum:
				if len(field.EnumValues) <= 4 {
					@renderRadioField(pluginID, field)
				} else {
					@renderSelectField(pluginID, field)
				}
			case settingsvm.FieldTypeCheckboxGroup:
				@renderCheckboxGroupField(pluginID, field)
			case settingsvm.FieldTypeTagInput:
				@renderTagInputField(pluginID, field)
			default:
				@renderTextField(pluginID, field)
		}
		<div id={ fmt.Sprintf("error-%s-%d", field.Key, pluginID) } class="settings-field-error">
			if field.Error != "" {
				{ field.Error }
			}
		</div>
	</div>
}

templ renderTextField(pluginID uint, field settingsvm.FieldViewModel) {
	<input
		type="text"
		name={ field.Key }
		value={ field.CurrentValue }
		class="settings-input"
		hx-post={ fmt.Sprintf("/api/settings/%d/validate-field", pluginID) }
		hx-trigger="blur changed"
		hx-target={ fmt.Sprintf("#error-%s-%d", field.Key, pluginID) }
		hx-swap="innerHTML"
		hx-include="[name='field_name']"
	/>
	<input type="hidden" name="field_name" value={ field.Key }/>
}

// renderTimeSelectField renders a <select> with half-hour time slots (00:00 – 23:30).
// Used for fields with an HH:MM pattern (e.g. preferred_time).
templ renderTimeSelectField(pluginID uint, field settingsvm.FieldViewModel) {
	<select
		name={ field.Key }
		class="settings-select"
		hx-post={ fmt.Sprintf("/api/settings/%d/validate-field", pluginID) }
		hx-trigger="change"
		hx-target={ fmt.Sprintf("#error-%s-%d", field.Key, pluginID) }
		hx-swap="innerHTML"
		hx-include="[name='field_name']"
	>
		for _, slot := range timeSlots() {
			<option value={ slot } if slot == field.CurrentValue { selected }>{ slot }</option>
		}
	</select>
	<input type="hidden" name="field_name" value={ field.Key }/>
}

templ renderIntegerField(pluginID uint, field settingsvm.FieldViewModel) {
	<input
		type="number"
		name={ field.Key }
		value={ field.CurrentValue }
		class="settings-input"
		hx-post={ fmt.Sprintf("/api/settings/%d/validate-field", pluginID) }
		hx-trigger="blur changed"
		hx-target={ fmt.Sprintf("#error-%s-%d", field.Key, pluginID) }
		hx-swap="innerHTML"
		hx-include="[name='field_name']"
	/>
	<input type="hidden" name="field_name" value={ field.Key }/>
}

templ renderBooleanField(pluginID uint, field settingsvm.FieldViewModel) {
	<!-- Hidden false value ensures unchecked state sends "false" (Pitfall 3) -->
	<input type="hidden" name={ field.Key } value="false"/>
	<label class="settings-toggle settings-toggle-inline">
		<input
			type="checkbox"
			name={ field.Key }
			value="true"
			if field.CurrentValue == "true" {
				checked
			}
		/>
		<span class="settings-toggle-slider"></span>
	</label>
}

templ renderRadioField(pluginID uint, field settingsvm.FieldViewModel) {
	<div class="settings-radio-group">
		for _, opt := range field.EnumValues {
			<label class="settings-radio-label">
				<input
					type="radio"
					name={ field.Key }
					value={ opt }
					class="settings-radio"
					if opt == field.CurrentValue {
						checked
					}
				/>
				{ opt }
			</label>
		}
	</div>
}

templ renderSelectField(pluginID uint, field settingsvm.FieldViewModel) {
	<select
		name={ field.Key }
		class="settings-select"
		hx-post={ fmt.Sprintf("/api/settings/%d/validate-field", pluginID) }
		hx-trigger="change"
		hx-target={ fmt.Sprintf("#error-%s-%d", field.Key, pluginID) }
		hx-swap="innerHTML"
		hx-include="[name='field_name']"
	>
		for _, opt := range field.EnumValues {
			<option
				value={ opt }
				if opt == field.CurrentValue {
					selected
				}
			>{ opt }</option>
		}
	</select>
	<input type="hidden" name="field_name" value={ field.Key }/>
}

templ renderCheckboxGroupField(pluginID uint, field settingsvm.FieldViewModel) {
	<div class="settings-checkbox-group">
		for _, opt := range field.EnumValues {
			<label class="settings-checkbox-label">
				<input
					type="checkbox"
					name={ field.Key }
					value={ opt }
					class="settings-checkbox"
					if isChecked(opt, field.CurrentValue) {
						checked
					}
				/>
				{ opt }
			</label>
		}
	</div>
}

// renderTagInputField renders an open-ended tag input for array fields without enum constraints.
// Tags are stored as a JSON array in a hidden input. JavaScript (initTagInputs) wires it up.
templ renderTagInputField(pluginID uint, field settingsvm.FieldViewModel) {
	<div class="settings-tag-input-wrapper">
		<div class="settings-tag-list"></div>
		<input
			type="text"
			class="settings-tag-text-input settings-input"
			placeholder="Type a tag and press Enter"
			autocomplete="off"
		/>
		<input type="hidden" name={ field.Key } class="settings-tag-hidden" value={ field.CurrentValue }/>
	</div>
	<p class="settings-tag-hint">Press Enter or comma to add a tag. Backspace removes the last tag.</p>
}

// PluginStatusSection renders the plugin run status panel.
templ PluginStatusSection(plugin settingsvm.PluginSettingsViewModel) {
	<div class="settings-status-section">
		<h3 class="settings-section-heading">Status</h3>
		if plugin.Status == nil {
			<p class="content-empty">No runs yet.</p>
		} else {
			<div class="settings-status-items">
				<div class="settings-status-item">
					<span class="settings-status-label">Last run</span>
					<span class="settings-status-value">
						if plugin.Status.LastRunAt != nil {
							{ plugin.Status.LastRunAt.Format("Jan 2 at 3:04 PM") }
						} else {
							Never
						}
					</span>
				</div>
				<div class="settings-status-item">
					<span class="settings-status-label">Next run</span>
					<span class="settings-status-value">
						if plugin.Status.NextRunAt != nil {
							{ plugin.Status.NextRunAt.Format("Jan 2 at 3:04 PM") }
						} else {
							No schedule set
						}
					</span>
				</div>
			</div>
			if len(plugin.Status.RecentErrors) > 0 {
				<div class="settings-errors-section">
					<h4 class="settings-subsection-heading">Recent Errors</h4>
					for _, errEntry := range plugin.Status.RecentErrors {
						<div class="settings-error-item">
							<span class="settings-error-time">{ errEntry.OccurredAt.Format("Jan 2 3:04 PM") }</span>
							<span class="settings-error-message">{ errEntry.Message }</span>
						</div>
					}
				</div>
			}
		}
		<!-- Run Now button — always shown if plugin is enabled -->
		if plugin.Enabled {
			<div class="settings-run-now-section">
				<button
					id={ fmt.Sprintf("run-now-%d", plugin.PluginID) }
					class="glass-btn glass-btn-primary glass-btn-sm"
					hx-post={ fmt.Sprintf("/api/settings/%d/run-now", plugin.PluginID) }
					hx-target={ fmt.Sprintf("#run-now-%d", plugin.PluginID) }
					hx-swap="innerHTML"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<polygon points="5 3 19 12 5 21 5 3"></polygon>
					</svg>
					Run Now
				</button>
			</div>
		}
	</div>
}
